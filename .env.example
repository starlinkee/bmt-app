# Database
DATABASE_URL="file:../app_data/database/dev.db"

# Authentication (next-auth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"

# App password (bcrypt hash)
APP_PASSWORD="your-bcrypt-hashed-password"

# Google Sheets — rozliczenia mediów (service account)
GOOGLE_SERVICE_ACCOUNT_JSON="base64-encoded-service-account-json"

# Google Drive OAuth2 — zapis rachunków PDF (uruchom scripts/get-drive-token.mjs aby uzyskać refresh token)
GOOGLE_OAUTH_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REFRESH_TOKEN=""

# Resend — wysyłka e-maili do najemców (resend.com)
